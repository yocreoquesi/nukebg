/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  # COEP removed — was blocking cross-origin fetch to HuggingFace CDN for model download
  # SharedArrayBuffer (which needs COEP) is not critical for our use case
  # CSP temporarily removed — was blocking WebAssembly.instantiate() in ONNX Runtime
  # despite wasm-unsafe-eval + unsafe-eval being present. Will re-add once confirmed working.

/assets/*
  Cache-Control: public, max-age=31536000, immutable
